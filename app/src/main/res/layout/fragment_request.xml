<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/requestLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#F0F2F5"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/rootRequestContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- CURRENT SCHEDULE HEADER -->
        <TextView
            android:id="@+id/scheduleStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: ..."
            android:textAlignment="center"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"
            android:padding="8dp"
            android:background="#DDDDDD"
            android:textColor="#000000" />

        <LinearLayout
            android:id="@+id/scheduleContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp" />

        <!-- EDIT CURRENT SCHEDULE BUTTON -->
        <LinearLayout
            android:id="@+id/editCurrentScheduleBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="@drawable/btn_light_border"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="@color/blacks"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edit Current Schedule"
                android:textSize="16sp"
                android:textColor="#000000" />
        </LinearLayout>

        <!-- REQUEST NEW WEEKLY SCHEDULE BUTTON -->
        <LinearLayout
            android:id="@+id/requestNewWeeklyBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="@drawable/btn_light_border"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_input_add"
                app:tint="@color/blacks"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Request New Weekly Schedule"
                android:textSize="16sp"
                android:textColor="#000000" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/yourRequestsBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="@drawable/btn_light_border"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_recent_history"
                app:tint="@color/blacks"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Requests"
                android:textSize="16sp"
                android:textColor="#000000" />
        </LinearLayout>

        <!-- NEW: INFORM ABSENCE BUTTON -->
        <LinearLayout
            android:id="@+id/informAbsenceBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="@drawable/btn_light_border"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_dialog_email"
                app:tint="@color/blacks"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Send Absent Notice"
                android:textSize="16sp"
                android:textColor="#000000" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>